{
  "name": "zenvy-monorepo",
  "version": "1.0.0",
  "description": "Zenvy — Open Source Package Manager. Scripted by Wyatt Mouris.",
  "private": true,
  "workspaces": ["cli", "registry"],
  "scripts": {
    "install:cli": "cd cli && npm install",
    "install:registry": "cd registry && npm install",
    "install:all": "npm run install:cli && npm run install:registry",
    "start:registry": "cd registry && npm start",
    "dev:registry": "cd registry && npm run dev",
    "build:installer": "cd installer && build.bat",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "author": "Wyatt Mouris",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mouriswyatt66-alt/Zenvy-Official"
  }
}
